<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xmlns:context="http://www.springframework.org/schema/context" xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd
        http://www.springframework.org/schema/context http://www.springframework.org/schema/context/spring-context.xsd"> <!-- bean definitions here -->


	<bean id="book" class="com.assignment.dataclass.Book">
		<property name="bookId" value="101"/>
		<property name="author" value="Rod Johnson"/>
		<property name="title" value="Spring Framework"/>
	</bean>
	
	<bean id="librarian" class="com.assignment.dataclass.Librarian">
		<property name="librarianId" value="12345"/>
		<property name="name" value="Amit"/>
		<property name="book" ref="book"/>
	</bean>
</beans>